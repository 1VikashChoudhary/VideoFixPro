<Window x:Class="VideoFixPro.AudioMuxerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio Muxer Settings"
        Width="560"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        Icon="Assets/app_icon.png">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.ColumnSpan="3"
                   Text="Audio Muxer Settings"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="16"
                   FontWeight="SemiBold"/>

        <TextBlock Grid.Row="1"
                   Text="FFmpeg path"
                   Foreground="{StaticResource Text2Brush}"
                   VerticalAlignment="Center"
                   Margin="0,14,0,0"/>
        <TextBox x:Name="FfmpegPathBox"
                 Grid.Row="1" Grid.Column="1"
                 Margin="0,14,8,0"/>
        <Button Grid.Row="1" Grid.Column="2"
                Content="Browse"
                Style="{StaticResource GhostButton}"
                Margin="0,14,0,0"
                Click="BrowseFfmpeg_Click"/>

        <TextBlock Grid.Row="2"
                   Text="FFprobe path"
                   Foreground="{StaticResource Text2Brush}"
                   VerticalAlignment="Center"
                   Margin="0,12,0,0"/>
        <TextBox x:Name="FfprobePathBox"
                 Grid.Row="2" Grid.Column="1"
                 Margin="0,12,8,0"/>
        <Button Grid.Row="2" Grid.Column="2"
                Content="Browse"
                Style="{StaticResource GhostButton}"
                Margin="0,12,0,0"
                Click="BrowseFfprobe_Click"/>

        <TextBlock Grid.Row="3"
                   Text="Default CRF"
                   Foreground="{StaticResource Text2Brush}"
                   VerticalAlignment="Center"
                   Margin="0,12,0,0"/>
        <TextBox x:Name="DefaultCrfBox"
                 Grid.Row="3" Grid.Column="1"
                 Width="80"
                 HorizontalAlignment="Left"
                 Margin="0,12,0,0"/>

        <TextBlock Grid.Row="4" Grid.ColumnSpan="3"
                   Margin="0,18,0,0"
                   Foreground="{StaticResource MutedBrush}"
                   TextWrapping="Wrap"
                   Text="These settings are stored locally for the audio muxer tool. The window follows VideoFixPro styling automatically."/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Width="92"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Style="{StaticResource PrimaryButton}"
                    Width="92"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
