<Window x:Class="VideoFixPro.BatchMuxWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Video + Audio Wizard"
        Width="1240"
        Height="760"
        MinWidth="1020"
        MinHeight="620"
        Background="{StaticResource BgBrush}"
        Icon="Assets/app_icon.png">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <StackPanel>
                <TextBlock Text="Batch Video + Audio Wizard"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource Text2Brush}"
                           TextWrapping="Wrap"
                           Text="Add the videos you want to process, then choose the matching external audio file for each row. The current output settings from the main muxer will be used when these jobs are queued."/>
            </StackPanel>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,12,0,12">
            <Button Content="Add Videos..."
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,8"
                    Click="AddVideos_Click"/>
            <Button Content="Choose Audio for Selected"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,8"
                    Click="ChooseAudioForSelected_Click"/>
            <Button Content="Auto-Match Audio Folder..."
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,8"
                    Click="AutoMatchFolder_Click"/>
            <Button Content="Clear Selected Audio"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,8"
                    Click="ClearSelectedAudio_Click"/>
            <Button Content="Remove Selected Video"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,8"
                    Click="RemoveSelected_Click"/>
            <Button Content="Clear All"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,8,8"
                    Click="ClearAll_Click"/>
        </WrapPanel>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                        <DataGrid x:Name="BatchGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  ItemsSource="{Binding Rows}"
                                  SelectionMode="Single"
                                  MouseDoubleClick="BatchGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Video" Binding="{Binding VideoPath}" Width="2.2*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Audio" Binding="{Binding AudioPath}" Width="2.2*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                        <DataGridTextColumn Header="Lang" Binding="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="Delay (s)" Binding="{Binding DelaySeconds, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                        <DataGridTextColumn Header="Output" Binding="{Binding OutputPath}" Width="1.8*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock x:Name="SummaryText"
                           Grid.Row="1"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource Text2Brush}"
                           Text="No videos added yet."/>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="HintText"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource AccentBrush}"
                       Text="Tip: double-click a row to choose its audio file quickly."/>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Style="{StaticResource GhostButton}"
                    Width="110"
                    Click="Cancel_Click"/>
            <Button Grid.Column="3"
                    Content="Queue Ready Jobs"
                    Style="{StaticResource PrimaryButton}"
                    Width="150"
                    Click="QueueReady_Click"/>
        </Grid>
    </Grid>
</Window>
