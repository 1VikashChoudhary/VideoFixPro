<Window x:Class="VideoFixPro.AudioMuxerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:VideoFixPro.Models"
        Title="Multi Audio Muxer"
        Width="1380"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource BgBrush}"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop"
        Icon="Assets/app_icon.png">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Start"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            ToolTip="Start processing the queued audio mux jobs"
                            Click="StartQueue_Click"/>
                    <Button Content="Stop"
                            Style="{StaticResource DangerButton}"
                            Margin="0,0,8,0"
                            ToolTip="Stop the current muxing job or queue"
                            Click="StopQueue_Click"/>
                    <Button Content="Refresh Hardware"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            ToolTip="Re-scan and re-apply the best working hardware encoder"
                            Click="DetectHw_Click"/>
                    <Button Content="Check Encoder"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            ToolTip="Advanced check for the currently selected hardware encoder"
                            Click="TestEncoder_Click"/>
                    <Button Content="Settings"
                            Style="{StaticResource GhostButton}"
                            ToolTip="FFmpeg paths and audio muxer defaults"
                            Click="Settings_Click"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           x:Name="MuxerTitleHint"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Text2Brush}"
                           FontSize="12"
                           Text="Hardware is detected automatically. Drop video/audio files and start."/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2"
                                   Text="1. Source Video and Appended Audio"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>

                        <Button Grid.Row="1"
                                Content="Browse Video..."
                                Style="{StaticResource GhostButton}"
                                Margin="0,12,10,0"
                                Click="BrowseVideo_Click"/>
                        <TextBlock x:Name="VideoPathText"
                                   Grid.Row="1" Grid.Column="1"
                                   Margin="0,18,0,0"
                                   Foreground="{StaticResource Text2Brush}"
                                   Text="No video selected"
                                   TextTrimming="CharacterEllipsis"/>

                        <DataGrid x:Name="TrackGrid"
                                  Grid.Row="2" Grid.ColumnSpan="2"
                                  Margin="0,14,0,0"
                                  Height="210"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  ItemsSource="{Binding AudioTracks}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                                <DataGridTextColumn Header="Lang" Binding="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                <DataGridTextColumn Header="Delay (s)" Binding="{Binding DelaySeconds, StringFormat=F3, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                                <DataGridTextColumn Header="File" Binding="{Binding Path}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0">
                            <Button Content="Add Audio" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="AddAudio_Click"/>
                            <Button Content="Dual Audio (Hi + En)" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="AddDualPreset_Click"/>
                            <Button Content="Rename" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="RenameTrack_Click"/>
                            <Button Content="Language" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="SetLanguage_Click"/>
                            <Button Content="Delay" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="SetDelay_Click"/>
                            <Button Content="Move Up" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="MoveTrackUp_Click"/>
                            <Button Content="Move Down" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="MoveTrackDown_Click"/>
                            <Button Content="Remove" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="RemoveTrack_Click"/>
                            <Button Content="Clear All" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="ClearTracks_Click"/>
                        </WrapPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="2. Output Settings"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Container" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="ContainerMp4Radio" Content="MP4" IsChecked="True" Margin="0,0,12,0" Checked="Container_Changed"/>
                                <RadioButton x:Name="ContainerMkvRadio" Content="MKV" Checked="Container_Changed"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="Audio mode" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <RadioButton x:Name="AudioFastRadio" Content="Fast (copy)" IsChecked="True" Margin="0,0,12,0"/>
                                <RadioButton x:Name="AudioSafeRadio" Content="Safe (AAC re-encode)"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox x:Name="ReencodeCheck"
                                      Grid.ColumnSpan="2"
                                      Content="Re-encode / Compress video"
                                      IsChecked="False"
                                      ToolTip="Optional. Leave this off for fastest stream-copy muxing."
                                      Foreground="{StaticResource TextBrush}"/>

                            <TextBlock Grid.Column="2" Text="HW encoder" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="HardwareEncoderBox" Grid.Column="3" SelectedIndex="0"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="CRF" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="CrfBox" Grid.Column="1" Width="80" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="Resolution" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ResolutionBox" Grid.Column="3">
                                <ComboBoxItem Content="same" IsSelected="True"/>
                                <ComboBoxItem Content="1920x1080"/>
                                <ComboBoxItem Content="1280x720"/>
                                <ComboBoxItem Content="854x480"/>
                                <ComboBoxItem Content="640x360"/>
                            </ComboBox>
                            <TextBlock Grid.Column="4" Text="Max bitrate" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="MaxBitrateBox" Grid.Column="5" Margin="0,0,10,0"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Bitrate preset" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <ComboBox x:Name="BitratePresetBox" Grid.Column="1" SelectionChanged="BitratePresetBox_SelectionChanged"/>
                            <TextBlock x:Name="SuggestedBitrateText" Grid.Column="2" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Output file" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OutputPathText" Grid.Column="1" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Content="Browse..." Style="{StaticResource GhostButton}" Margin="10,0,0,0" Click="BrowseOutput_Click"/>
                        </Grid>

                        <WrapPanel Margin="0,14,0,0">
                            <Button Content="Set Default (Appended)" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="SetDefaultTrack_Click"/>
                            <Button Content="Default Original" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="SetOriginalDefault_Click"/>
                            <CheckBox x:Name="KeepOriginalAudioCheck" Content="Keep original video audio" IsChecked="True" Foreground="{StaticResource TextBrush}" Margin="0,3,18,8"/>
                            <TextBlock x:Name="DefaultTrackText" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,3,0,8"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Sample Encode (10s)" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="Sample10_Click"/>
                            <Button Content="Sample Encode (5s)" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="Sample5_Click"/>
                            <Button Content="Add to Job Queue" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8" Click="AddCurrentJob_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="3. Job Queue"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <WrapPanel Margin="0,12,0,0">
                            <Button Content="Batch Wizard..." Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="AddFilesToQueue_Click"
                                    ToolTip="Choose many videos, then assign a matching audio file for each one in a dedicated batch wizard"/>
                            <Button Content="Remove Selected" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="RemoveSelectedJob_Click"/>
                            <Button Content="Move Up" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="MoveJobUp_Click"/>
                            <Button Content="Move Down" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="MoveJobDown_Click"/>
                            <Button Content="Clear Queue" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="ClearQueue_Click"/>
                            <Button x:Name="OpenFolderBtn" Content="Open Output Folder" Style="{StaticResource GhostButton}" Margin="0,0,8,8" Click="OpenOutputFolder_Click"/>
                        </WrapPanel>
                        <DataGrid x:Name="JobGrid"
                                  Margin="0,4,0,0"
                                  Height="220"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  ItemsSource="{Binding JobQueue}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Input" Binding="{Binding InputPath}" Width="*"/>
                                <DataGridTextColumn Header="Output" Binding="{Binding OutputPath}" Width="*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="FFmpeg Log and Stats"
                           Foreground="{StaticResource TextBrush}"
                           FontWeight="SemiBold"
                           FontSize="14"/>

                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Margin="0,12,0,0"
                         Background="{StaticResource LogBgBrush}"
                         Foreground="{StaticResource LogTextBrush}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"/>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Progress" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center"/>
                    <ProgressBar x:Name="MuxProgressBar" Grid.Column="1" Margin="10,0" Height="18" Minimum="0" Maximum="100"/>
                    <TextBlock x:Name="MuxProgressText" Grid.Column="2" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Text="0%"/>
                </Grid>

                <UniformGrid Grid.Row="3" Margin="0,12,0,0" Columns="2">
                    <TextBlock x:Name="StatFpsText" Foreground="{StaticResource Text2Brush}" Text="FPS: N/A"/>
                    <TextBlock x:Name="StatSpeedText" Foreground="{StaticResource Text2Brush}" Text="Speed: N/A"/>
                    <TextBlock x:Name="StatBitrateText" Foreground="{StaticResource Text2Brush}" Text="Bitrate: N/A"/>
                    <TextBlock x:Name="StatGpuText" Foreground="{StaticResource Text2Brush}" Text="GPU: N/A"/>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource Text2Brush}" VerticalAlignment="Center" Text="Ready"/>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       HorizontalAlignment="Right"
                       Foreground="{StaticResource MutedBrush}"
                       Text="Audio Muxer for VideoFixPro"/>
        </Grid>
    </Grid>
</Window>
