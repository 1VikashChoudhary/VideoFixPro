<Window x:Class="VideoFixPro.TrimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:VideoFixPro"
        xmlns:models="clr-namespace:VideoFixPro.Models"
        Title="Video Trim Tool"
        Width="1134" Height="775"
        MinWidth="880" MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{StaticResource BgBrush}"
        AllowDrop="True"
        Icon="Assets/app_icon.png"
        KeyDown="Window_KeyDown">

    <!-- Custom window chrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6"
                            GlassFrameThickness="0,0,0,1" CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Segment ListView item style -->
        <Style x:Key="SegmentItem" TargetType="ListViewItem">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="Margin"           Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="4,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F3152"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style for time inputs -->
        <Style x:Key="TimeInputBox" TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource CardBrush}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,5"/>
            <Setter Property="FontFamily"       Value="Consolas, Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Height"           Value="32"/>
            <Setter Property="CaretBrush"       Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush"   Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  ROOT GRID                                                   -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <!-- Title bar -->
            <RowDefinition Height="1"/>
            <!-- Separator -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="30"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ════════════════ TITLE BAR ════════════════ -->
        <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}"
              MouseLeftButtonDown="TitleBar_MouseDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <TextBlock Text="✂" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Video Trim Tool" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                <Border Background="#21262D" CornerRadius="3" Padding="6,1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="TrimFileName" Text="No file loaded"
                               FontSize="10" Foreground="{StaticResource Text2Brush}"
                               FontFamily="Segoe UI" MaxWidth="360"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="─" Style="{StaticResource TitleBarButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="MinBtn_Click"/>
                <Button x:Name="TrimMaxBtn" Content="□" Style="{StaticResource TitleBarButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="MaxBtn_Click"/>
                <Button Content="✕" Style="{StaticResource TitleBarCloseButton}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="CloseBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{StaticResource BorderBrush}"/>

        <!-- ════════════════ MAIN CONTENT ════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="400"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="2*" MinWidth="290"/>
            </Grid.ColumnDefinitions>

            <!-- ─────── LEFT PANEL ─────── -->
            <Grid Grid.Column="0" Margin="14,12,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 0: Drop zone / file header -->
                    <RowDefinition Height="*"/>    <!-- 1: Live Media Preview -->
                    <RowDefinition Height="Auto"/> <!-- 2: Filmstrip -->
                    <RowDefinition Height="Auto"/> <!-- 3: Timeline canvas -->
                    <RowDefinition Height="Auto"/> <!-- 4: Time labels -->
                    <RowDefinition Height="Auto"/> <!-- 5: Quick action buttons -->
                    <RowDefinition Height="Auto"/> <!-- 6: Segments list -->
                </Grid.RowDefinitions>

                <!-- ── DROP ZONE (visible until file loaded) ── -->
                <Border x:Name="TrimDropZone"
                        Grid.Row="0"
                        Height="100"
                        BorderBrush="{StaticResource MutedBrush}"
                        BorderThickness="2" CornerRadius="8"
                        Background="{StaticResource SurfaceBrush}"
                        AllowDrop="True"
                        DragEnter="TrimDrop_DragEnter"
                        DragOver="TrimDrop_DragOver"
                        DragLeave="TrimDrop_DragLeave"
                        Drop="TrimDrop_Drop"
                        Cursor="Hand"
                        MouseLeftButtonDown="TrimDrop_Click">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1C2128"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="TrimDropIcon" Text="✂"
                                   FontSize="26" HorizontalAlignment="Center"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Drop a video file here to trim"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontFamily="Segoe UI" FontSize="13"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="or click to browse  •  MP4, MKV, AVI, MOV, WMV, FLV"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontFamily="Segoe UI" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── FILE HEADER (replaces drop zone after load) ── -->
                <Border x:Name="TrimFileHeader"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="🎬 " FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock x:Name="HeaderFileName"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" MaxWidth="360"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource CardBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock x:Name="HeaderDuration" Text="—"
                                               Foreground="{StaticResource Text2Brush}"
                                               FontFamily="Segoe UI" FontSize="11"/>
                                </Border>
                                <Border Background="{StaticResource CardBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                                    <TextBlock x:Name="HeaderCodec" Text="—"
                                               Foreground="{StaticResource Text2Brush}"
                                               FontFamily="Segoe UI" FontSize="11"/>
                                </Border>
                                <Border Background="{StaticResource CardBrush}" CornerRadius="3" Padding="6,2">
                                    <TextBlock x:Name="HeaderResolution" Text="—"
                                               Foreground="{StaticResource Text2Brush}"
                                               FontFamily="Segoe UI" FontSize="11"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Change File"
                                Style="{StaticResource GhostButton}"
                                VerticalAlignment="Center" Padding="10,6"
                                Click="ChangeFile_Click" ToolTip="Load a different video file"/>
                    </Grid>
                </Border>

                <!-- ── LIVE MEDIA PREVIEW ── -->
                <Border x:Name="PlayerBorder"
                        Grid.Row="1" Margin="0,10,0,0"
                        Background="Black" CornerRadius="8" ClipToBounds="True"
                        Visibility="Collapsed" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <MediaElement x:Name="TrimPlayer"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Stop"
                                      ScrubbingEnabled="True"
                                      Volume="0.5"
                                      Stretch="Uniform"
                                      MediaOpened="TrimPlayer_MediaOpened"
                                      MediaEnded="TrimPlayer_MediaEnded"/>

                        <!-- Playback Overlay -->
                        <Button x:Name="PlayPauseBtn"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Width="60" Height="60"
                                Style="{StaticResource GhostButton}"
                                FontSize="30" Content="▶"
                                Opacity="0.6"
                                Visibility="Collapsed"
                                Click="TogglePlay_Click"
                                MouseEnter="PlayPauseBtn_MouseEnter"
                                MouseLeave="PlayPauseBtn_MouseLeave"/>
                    </Grid>
                </Border>

                <!-- ── FILMSTRIP ── -->
                <Border x:Name="FilmstripBorder"
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Height="56"
                        Background="#090C10"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        ClipToBounds="True"
                        Visibility="Collapsed">
                    <!-- Playhead indicator line over filmstrip -->
                    <Grid>
                        <Canvas x:Name="FilmstripCanvas"/>
                        <!-- Playhead overlay line -->
                        <Rectangle x:Name="FilmstripPlayhead"
                                   Width="2" HorizontalAlignment="Left"
                                   Fill="{StaticResource AccentBrush}"
                                   Opacity="0.8"/>
                    </Grid>
                </Border>

                <!-- ── TIMELINE CANVAS ── -->
                <Border x:Name="TimelineBorder"
                        Grid.Row="3"
                        Margin="0,4,0,0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6"
                        Visibility="Collapsed"
                        Padding="0">
                    <Canvas x:Name="TimelineCanvas"
                            Height="84"
                            Cursor="Hand"
                            Background="Transparent"
                            ClipToBounds="True"
                            MouseDown="Timeline_MouseDown"
                            MouseMove="Timeline_MouseMove"
                            MouseUp="Timeline_MouseUp"
                            MouseLeave="Timeline_MouseLeave"
                            SizeChanged="Timeline_SizeChanged"
                            Loaded="Timeline_Loaded"/>
                </Border>

                <!-- ── TIME LABELS ── -->
                <Grid x:Name="TimeLabelsGrid"
                      Grid.Row="4"
                      Margin="2,3,2,0"
                      Visibility="Collapsed">
                    <TextBlock x:Name="LabelTimeStart" Text="00:00.0"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Segoe UI" FontSize="10"
                               HorizontalAlignment="Left"/>
                    <TextBlock x:Name="LabelTimeCurrent" Text="00:00.0"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI" FontSize="10"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LabelTimeEnd" Text="00:00.0"
                               Foreground="{StaticResource MutedBrush}"
                               FontFamily="Segoe UI" FontSize="10"
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- ── QUICK BUTTONS ── -->
                <Grid x:Name="QuickButtonsGrid"
                      Grid.Row="5"
                      Margin="0,8,0,0"
                      Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="[ Set In"
                                Style="{StaticResource GhostButton}"
                                Padding="10,5" FontSize="12"
                                Margin="0,0,5,0"
                                Click="SetIn_Click"
                                ToolTip="Set In point to playhead  (I)"/>
                        <Button Content="Set Out ]"
                                Style="{StaticResource GhostButton}"
                                Padding="10,5" FontSize="12"
                                Margin="0,0,5,0"
                                Click="SetOut_Click"
                                ToolTip="Set Out point to playhead  (O)"/>
                        <Button Content="↩ Full"
                                Style="{StaticResource GhostButton}"
                                Padding="10,5" FontSize="12"
                                Margin="0,0,5,0"
                                Click="ResetPoints_Click"
                                ToolTip="Reset In/Out to full duration"/>
                        <Button Content="▶ Preview"
                                Style="{StaticResource GhostButton}"
                                Padding="10,5" FontSize="12"
                                Click="Preview_Click"
                                ToolTip="Open video at current playhead position in system player"/>
                    </StackPanel>

                    <!-- Selection duration badge -->
                    <Border Background="{StaticResource CardBrush}" CornerRadius="4"
                            Padding="8,3" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="SelectionDurationBadge"
                                   Text="Selection: —"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="Segoe UI" FontSize="11"/>
                    </Border>
                </Grid>

                <!-- ── SEGMENTS SECTION ── -->
                <Border x:Name="SegmentsBorder"
                        Grid.Row="6"
                        Margin="0,12,0,0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Visibility="Collapsed"
                        Padding="12,10">
                    <StackPanel>
                        <!-- Header row -->
                        <Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="TRIM SEGMENTS"
                                           Foreground="{StaticResource Text2Brush}"
                                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="SegmentCountBadge"
                                        Background="{StaticResource CardBrush}"
                                        CornerRadius="8" Padding="6,1" Margin="7,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="SegmentCountText" Text="1"
                                               Foreground="{StaticResource Text2Brush}"
                                               FontFamily="Segoe UI" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="+ Add"
                                        Style="{StaticResource GhostButton}"
                                        Padding="8,4" FontSize="11" Margin="0,0,5,0"
                                        Click="AddSegment_Click"
                                        ToolTip="Save current In/Out as a new segment"/>
                                <Button Content="🗑 Remove"
                                        Style="{StaticResource GhostButton}"
                                        Padding="8,4" FontSize="11"
                                        Click="RemoveSegment_Click"
                                        ToolTip="Remove selected segment"/>
                            </StackPanel>
                        </Grid>

                        <!-- Segment list -->
                        <ListView x:Name="SegmentList"
                                  MaxHeight="130"
                                  ItemContainerStyle="{StaticResource SegmentItem}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  SelectionChanged="SegmentList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:TrimSegment}">
                                    <Grid Margin="2,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Index badge -->
                                        <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                                                CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontFamily="Segoe UI" FontSize="11"/>
                                        </Border>

                                        <!-- Times -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StartFormatted}"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       FontFamily="Segoe UI" FontSize="11"/>
                                            <TextBlock Text=" → "
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontFamily="Segoe UI" FontSize="11"/>
                                            <TextBlock Text="{Binding EndFormatted}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       FontFamily="Segoe UI" FontSize="11"/>
                                        </StackPanel>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DurationFormatted}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontFamily="Segoe UI" FontSize="11"
                                                   Margin="10,0"
                                                   VerticalAlignment="Center"/>

                                        <!-- Load into editor button -->
                                        <Button Grid.Column="3"
                                                Content="Edit"
                                                Style="{StaticResource GhostButton}"
                                                Padding="6,2" FontSize="10"
                                                Tag="{Binding}"
                                                Click="LoadSegmentIntoEditor_Click"
                                                ToolTip="Load this segment into the timeline editor"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Concat option -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="5"
                                Padding="10,7" Margin="0,8,0,0">
                            <CheckBox x:Name="ConcatCheck"
                                      Content="Merge all segments into one output file"
                                      IsChecked="True"
                                      Foreground="{StaticResource Text2Brush}"
                                      FontFamily="Segoe UI" FontSize="11"
                                      Cursor="Hand"
                                      ToolTip="When checked, all segments are trimmed then joined into a single file. When unchecked, each segment produces its own output file."/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Vertical separator -->
            <Rectangle Grid.Column="1" Fill="{StaticResource BorderBrush}"/>

            <!-- ─────── RIGHT PANEL ─────── -->
            <Grid Grid.Column="2" Margin="10,12,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Trim points card -->
                    <RowDefinition Height="Auto"/>
                    <!-- Output settings card -->
                    <RowDefinition Height="Auto"/>
                    <!-- Keyboard shortcuts hint -->
                    <RowDefinition Height="*"/>
                    <!-- Spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- Action buttons -->
                </Grid.RowDefinitions>

                <!-- ── TRIM POINTS CARD ── -->
                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="TRIM POINTS"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <!-- In point row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <!-- colour bar -->
                                <ColumnDefinition Width="42"/>
                                <!-- label -->
                                <ColumnDefinition Width="*"/>
                                <!-- input -->
                                <ColumnDefinition Width="46"/>
                                <!-- set button -->
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Width="3" Height="24"
                                       Fill="{StaticResource SuccessBrush}"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="Start"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="InTimeBox"
                                     Grid.Column="2"
                                     Style="{StaticResource TimeInputBox}"
                                     Text="00:00.0"
                                     ToolTip="Format: mm:ss.f  or  hh:mm:ss.f  (edit then press Enter or click Set)"
                                     KeyDown="TimeBox_KeyDown"
                                     LostFocus="InTimeBox_LostFocus" FontSize="10" FontWeight="Bold"/>
                            <Button Grid.Column="3"
                                    Content="Set"
                                    Style="{StaticResource GhostButton}"
                                    Height="32" Margin="5,0,0,0" Padding="6,0"
                                    Click="SetInFromBox_Click"
                                    ToolTip="Apply typed start time"/>
                        </Grid>

                        <!-- Out point row -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Column="0" Width="3" Height="24"
                                       Fill="{StaticResource ErrorBrush}"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="End"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="OutTimeBox"
                                     Grid.Column="2"
                                     Style="{StaticResource TimeInputBox}"
                                     Text="00:00.0"
                                     ToolTip="Format: mm:ss.f  or  hh:mm:ss.f  (edit then press Enter or click Set)"
                                     KeyDown="TimeBox_KeyDown"
                                     LostFocus="OutTimeBox_LostFocus" SelectionOpacity="0.3" FontSize="10" TextChanged="OutTimeBox_TextChanged" FontWeight="Bold"/>
                            <Button Grid.Column="3"
                                    Content="Set"
                                    Style="{StaticResource GhostButton}"
                                    Height="32" Margin="5,0,0,0" Padding="6,0"
                                    Click="SetOutFromBox_Click"
                                    ToolTip="Apply typed end time"/>
                        </Grid>

                        <!-- Selection info badge -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="6" Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="SELECTION DURATION"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold"
                                               Margin="0,0,0,2"/>
                                    <TextBlock x:Name="SelectionDurationText"
                                               Text="—"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PLAYHEAD"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold"
                                               Margin="0,0,0,2" HorizontalAlignment="Right"/>
                                    <TextBlock x:Name="PlayheadTimeText"
                                               Text="—"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="Segoe UI" FontSize="12"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── OUTPUT SETTINGS CARD ── -->
                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="OUTPUT SETTINGS"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <!-- Trim mode -->
                        <TextBlock Text="Mode"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>
                        <RadioButton x:Name="TrimModeStreamCopy"
                                     Content="Stream Copy  ·  lossless, fast"
                                     IsChecked="True"
                                     Checked="TrimMode_Changed"
                                     ToolTip="Re-muxes without re-encoding. Cuts at keyframes — may be off by a fraction of a second."/>
                        <RadioButton x:Name="TrimModeReEncode"
                                     Content="Re-encode  ·  frame-accurate"
                                     Checked="TrimMode_Changed"
                                     Margin="0,3,0,0"
                                     ToolTip="Full H.264 + AAC re-encode. Exact frame-level accuracy. Slower."/>

                        <!-- Mode hint -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="4"
                                Padding="8,5" Margin="0,6,0,10">
                            <TextBlock x:Name="TrimModeHint"
                                       Text="Fast lossless cut. Output starts/ends on the nearest keyframe."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="Segoe UI" FontSize="10"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Format row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Format"
                                       Foreground="{StaticResource Text2Brush}"
                                       FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox x:Name="TrimFormatBox" Grid.Column="1" SelectedIndex="0">
                                <ComboBoxItem Content="MP4"/>
                                <ComboBoxItem Content="MKV"/>
                                <ComboBoxItem Content="AVI"/>
                                <ComboBoxItem Content="MOV"/>
                            </ComboBox>
                        </Grid>

                        <!-- Output folder row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Folder"
                                       Foreground="{StaticResource Text2Brush}"
                                       FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="5"
                                    Padding="8,5" Height="32">
                                <TextBlock x:Name="TrimOutputFolderText"
                                           Text="Same as source"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="2" Content="Browse"
                                    Style="{StaticResource GhostButton}"
                                    Margin="6,0,0,0" Height="32"
                                    Click="BrowseTrimOutput_Click"/>
                        </Grid>

                        <Button Content="↩ Reset to source folder"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Left"
                                Padding="0,3" BorderThickness="0"
                                FontSize="11" Margin="60,4,0,0"
                                Foreground="{StaticResource MutedBrush}"
                                Click="ResetTrimOutput_Click"/>
                    </StackPanel>
                </Border>

                <!-- ── KEYBOARD SHORTCUTS HINT ── -->
                <Border Grid.Row="2"
                        Margin="0,10,0,0"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource Border2Brush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="KEYBOARD SHORTCUTS"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontFamily="Segoe UI" FontSize="10" Margin="0,1">
                                <Run Text="I" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                <Run Text=" — Set In point"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontFamily="Segoe UI" FontSize="10" Margin="0,1">
                                <Run Text="O" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                <Run Text=" — Set Out point"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontFamily="Segoe UI" FontSize="10" Margin="0,1">
                                <Run Text="Space" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                <Run Text=" — Preview in player"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text=" " FontSize="9" Margin="0,0,0,5"/>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontFamily="Segoe UI" FontSize="10" Margin="0,1">
                                <Run Text="← →" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                <Run Text=" — ±1s"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontFamily="Segoe UI" FontSize="10" Margin="0,1">
                                <Run Text="⇧ ← →" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                <Run Text=" — ±10s"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource Text2Brush}" FontFamily="Segoe UI" FontSize="10" Margin="0,1">
                                <Run Text="Home / End" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                <Run Text=" — Jump"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Spacer -->
                <Grid Grid.Row="3"/>

                <!-- ── ACTION BUTTONS ── -->
                <StackPanel Grid.Row="4" Margin="0,10,0,0">

                    <!-- Add to queue button -->
                    <Button x:Name="AddToQueueBtn"
                            Content="+ Add Trim to Main Queue"
                            Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Stretch"
                            Height="32" Margin="0,0,0,6"
                            IsEnabled="False"
                            Click="AddToQueue_Click"
                            ToolTip="Send this trim job to the main window queue for batch processing"/>

                    <!-- Primary Trim button -->
                    <Button x:Name="TrimBtn"
                            Content="✂  Trim Video"
                            Style="{StaticResource PrimaryButton}"
                            Height="40" FontSize="14"
                            HorizontalAlignment="Stretch"
                            IsEnabled="False"
                            Click="TrimBtn_Click"/>

                    <!-- Progress bar -->
                    <ProgressBar x:Name="TrimProgressBar"
                                 Style="{StaticResource LinearProgress}"
                                 Margin="0,8,0,0"
                                 Value="0" Minimum="0" Maximum="100"
                                 Height="5"
                                 Visibility="Collapsed"/>

                    <!-- Progress text -->
                    <TextBlock x:Name="TrimProgressText"
                               Text=""
                               Foreground="{StaticResource Text2Brush}"
                               FontFamily="Segoe UI" FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"
                               Visibility="Collapsed"/>

                    <!-- Cancel + Open Folder row -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CancelTrimBtn"
                                Grid.Column="0"
                                Content="◼  Cancel"
                                Style="{StaticResource DangerButton}"
                                IsEnabled="False"
                                Height="34"
                                Click="CancelTrim_Click"/>
                        <Button x:Name="OpenTrimFolderBtn"
                                Grid.Column="2"
                                Content="📂  Open Folder"
                                Style="{StaticResource GhostButton}"
                                IsEnabled="False"
                                Height="34"
                                Click="OpenTrimFolder_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ════════════════ STATUS BAR ════════════════ -->
        <Grid Grid.Row="3" Background="{StaticResource TitleBarBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Ellipse x:Name="TrimStatusDot"
                         Width="7" Height="7"
                         Fill="{StaticResource MutedBrush}"
                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                <TextBlock x:Name="TrimStatusText"
                           Text="Load a video file to begin  •  Tip: I = Set In,  O = Set Out"
                           Foreground="{StaticResource Text2Brush}"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="✂ Video Trim Tool  •  ffmpeg"
                       Foreground="{StaticResource MutedBrush}"
                       FontFamily="Segoe UI" FontSize="10"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
        </Grid>
    </Grid>
</Window>
